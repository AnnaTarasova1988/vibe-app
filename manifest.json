// CHATS
function subChats(){
  if(unsubC)unsubC();
  const q=query(collection(db,'chats'),where('members','array-contains',cu.uid));
  unsubC=onSnapshot(q,snap=>{
    const chats=snap.docs.map(d=>({id:d.id,...d.data()}));
    chats.sort((a,b)=>(b.lastTime?.seconds||0)-(a.lastTime?.seconds||0));
    renderChats(chats);
  });
}
G.subC=subChats;

let prevU={};
function renderChats(chats){
  const list=$('cl');
  const srch=document.querySelector('.sinp').value.toLowerCase();
  let f=chats.filter(c=>{if(G.cf==='personal')return c.type!=='group';if(G.cf==='groups')return c.type==='group';return true;});
  if(srch)f=f.filter(c=>(c.name||'').toLowerCase().includes(srch)||Object.values(c.memberNames||{}).some(n=>n.toLowerCase().includes(srch)));

  chats.forEach(c=>{
    const u=c.unread?.[cu.uid]||0,pv=prevU[c.id]||0;
    if(u>pv&&c.id!==G.cid){
      const uid2=c.members.find(m=>m!==cu.uid);
      const nm=c.type==='group'?c.name:(c.memberNames?.[uid2]||'Контакт');
      playNotif();showNotif('Vibe — '+nm,c.lastMsg||'Новое сообщение');
    }
    prevU[c.id]=u;
  });

  if(!f.length){list.innerHTML='<div style="text-align:center;color:var(--tx3);padding:26px;font-size:13px;">Нет чатов</div>';return;}
  list.innerHTML=f.map(c=>{
    const uid2=c.members.find(m=>m!==cu.uid);
    const nm=c.type==='group'?c.name:(c.memberNames?.[uid2]||'Контакт');
    const col=avc(uid2||c.id);
    const u=c.unread?.[cu.uid]||0;
    return`<div class="ci${c.id===G.cid?' on':''}" onclick="openChat('${c.id}','${c.type||'personal'}')">
      <div class="cav" style="background:${col};">${ini(nm)}${c.type!=='group'?'<div class="od"></div>':''}</div>
      <div class="cii"><div class="cnm">${nm}</div><div class="cpv">${c.lastMsg||'Нет сообщений'}</div></div>
      <div class="cmeta">
        <div class="ctm">${ft(c.lastTime)}</div>
        ${u>0?`<div class="ubadge">${u}</div>`:''}
        <button class="delbtn" onclick="event.stopPropagation();delChatById('${c.id}')" title="Удалить">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
        </button>
      </div>
    </div>`;
  }).join('');
}

