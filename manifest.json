// ── INDEXED DB for media storage (base64 stays local, only URL ref in Firestore) ──
// We store media in IndexedDB so it persists and doesn't disappear
let idb=null;
function openIDB(){
  return new Promise((res,rej)=>{
    const rq=indexedDB.open('vibe-media',1);
    rq.onupgradeneeded=e=>{e.target.result.createObjectStore('media',{keyPath:'id'});};
    rq.onsuccess=e=>{idb=e.target.result;res(idb);};
    rq.onerror=rej;
  });
}
async function saveMedia(id,data){
  await openIDB();
  return new Promise((res,rej)=>{
    const tx=idb.transaction('media','readwrite');
    tx.objectStore('media').put({id,data});
    tx.oncomplete=res;tx.onerror=rej;
  });
}
async function getMedia(id){
  await openIDB();
  return new Promise((res)=>{
    const tx=idb.transaction('media','readonly');
    const req=tx.objectStore('media').get(id);
    req.onsuccess=e=>res(e.target.result?.data||null);
    req.onerror=()=>res(null);
  });
}
async function clearAllMedia(){
  await openIDB();
  return new Promise((res,rej)=>{
    const tx=idb.transaction('media','readwrite');
    tx.objectStore('media').clear();
    tx.oncomplete=res;tx.onerror=rej;
  });
}

