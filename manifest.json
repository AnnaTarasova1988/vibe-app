<script>
/* ── GLOBAL BRIDGE (onclick handlers need global scope) ── */
const G={};
function stab(t){G.tab=t;document.getElementById('tab-l').classList.toggle('on',t==='l');document.getElementById('tab-r').classList.toggle('on',t==='r');document.getElementById('lf').classList.toggle('hid',t==='r');document.getElementById('rf').classList.toggle('hid',t==='l');}
function closeModal(id){document.getElementById(id).classList.remove('on');}
function openProfile(){document.getElementById('ppnl').classList.add('on');}
function closePrf(){document.getElementById('ppnl').classList.remove('on');}
function openSettings(){document.getElementById('spnl').classList.add('on');}
function closeSettings(){document.getElementById('spnl').classList.remove('on');}
function openContacts(){document.getElementById('cpnl').classList.add('on');}
function closeContacts(){document.getElementById('cpnl').classList.remove('on');}
function toggleCtx(){document.getElementById('ctxm').classList.toggle('on');}
function goBack(){document.getElementById('sb').classList.remove('hid');document.getElementById('ca').classList.remove('on');}
function sctab(t,el){G.cf=t;document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('on'));el.classList.add('on');}
function fchats(){if(G.subC)G.subC();}
function ar(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,100)+'px';}
function mkd(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMsg();}}
function sendMsg(){if(G.send)G.send();}
function attachFile(i){if(G.attach)G.attach(i);}
function toggleEmoji(){document.getElementById('ep').classList.toggle('on');}
function insertEmoji(e){const i=document.getElementById('minp');i.value+=e;i.focus();document.getElementById('ep').classList.remove('on');}
function doLogin(){if(G.login)G.login();}
function doRegister(){if(G.reg)G.reg();}
function doLogout(){if(G.logout)G.logout();}
function saveSt(){if(G.saveSt)G.saveSt();}
function savePrf(){if(G.savePrf)G.savePrf();}
function openAddContact(){document.getElementById('cph').value='';document.getElementById('cerr').textContent='';document.getElementById('ufc').innerHTML='';document.getElementById('madc').classList.add('on');}
function searchC(){if(G.searchC)G.searchC();}
function confirmAddC(){if(G.confirmAddC)G.confirmAddC();}
function openChat(id,t){if(G.openChat)G.openChat(id,t);}
function startChat(uid,nm){if(G.startChat)G.startChat(uid,nm);}
function openNewGroup(){if(G.openNG)G.openNG();}
function toggleGM(uid,nm,el){if(G.toggleGM)G.toggleGM(uid,nm,el);}
function createGrp(){if(G.createGrp)G.createGrp();}
function confDelChat(){G.chatToDel=G.cid;document.getElementById('ctxm').classList.remove('on');document.getElementById('mdelc').classList.add('on');}
function delChatById(id){G.chatToDel=id;document.getElementById('mdelc').classList.add('on');}
function delChatOk(){if(G.delChat)G.delChat();}
function clearCurrentChat(){G.chatToClear=G.cid;document.getElementById('ctxm').classList.remove('on');document.getElementById('mclearc').classList.add('on');}
function clearCurrentChatFromSettings(){G.chatToClear=G.cid;closeSettings();document.getElementById('mclearc').classList.add('on');}
function clearChatOk(){if(G.clearChat)G.clearChat();}
function clearCache(){if(G.clearCache)G.clearCache();}
function startAudioCall(){if(G.call)G.call('audio');}
function startVideoCall(){if(G.call)G.call('video');}
function endCall(){if(G.endCall)G.endCall();}
function toggleMute(){if(G.toggleMute)G.toggleMute();}
function toggleSpk(){if(G.toggleSpk)G.toggleSpk();}
function toggleCam(){if(G.toggleCam)G.toggleCam();}
function openVR(){if(G.openVR)G.openVR();}
function closeVR(){if(G.closeVR)G.closeVR();}
function toggleVRec(){if(G.toggleVRec)G.toggleVRec();}
function flipCam(){if(G.flipCam)G.flipCam();}
function sendVRec(){if(G.sendVRec)G.sendVRec();}
function startRec(e){e.preventDefault();if(G.startRec)G.startRec();}
function cancelRec(){if(G.cancelRec)G.cancelRec();}
function sendRec(){if(G.sendRec)G.sendRec();}

G.cf='all';G.cid=null;G.chatToDel=null;G.chatToClear=null;

/* close on outside click */
document.addEventListener('click',ev=>{
  if(!ev.target.closest('.cpnl')&&!ev.target.closest('[onclick="openContacts()"]'))document.getElementById('cpnl').classList.remove('on');
  if(!ev.target.closest('#ctxm')&&!ev.target.closest('[onclick="toggleCtx()"]'))document.getElementById('ctxm').classList.remove('on');
  if(!ev.target.closest('#ep')&&!ev.target.closest('[onclick="toggleEmoji()"]'))document.getElementById('ep').classList.remove('on');
});
window.addEventListener('resize',()=>{const m=document.getElementById('msgs');if(m)m.scrollTop=m.scrollHeight;});
</script>

<script type="module">
