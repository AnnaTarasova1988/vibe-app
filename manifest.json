<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="theme-color" content="#0e0f14">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Vibe">
<title>Vibe</title>
<link rel="manifest" href="manifest.json">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#0e0f14;--bg2:#16181f;--bg3:#1e2029;--bg4:#252834;--ac:#6c63ff;--ac2:#a78bfa;--tx:#f0f0f5;--tx2:#9a9ab0;--tx3:#5a5a70;--br:rgba(255,255,255,0.08);--gn:#4ade80;--rd:#f87171;--fn:'Sora',sans-serif;}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;font-family:var(--fn);background:var(--bg);color:var(--tx);}
input,textarea,button{font-family:var(--fn);}

/* ─── AUTH ─── */
#auth{display:flex;align-items:center;justify-content:center;min-height:100dvh;flex-direction:column;background:radial-gradient(ellipse at 60% 20%,#1a1535,var(--bg) 65%);}
.logo{font-size:40px;font-weight:600;color:var(--ac2);letter-spacing:-1px;margin-bottom:4px;}
.logo-sub{font-size:13px;color:var(--tx3);margin-bottom:32px;}
.acard{background:var(--bg2);border:1px solid var(--br);border-radius:22px;padding:26px 22px;width:340px;max-width:94vw;}
.atabs{display:flex;gap:4px;background:var(--bg3);border-radius:11px;padding:3px;margin-bottom:20px;}
.atab{flex:1;padding:8px;border:none;background:transparent;border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--tx2);transition:all .2s;}
.atab.on{background:var(--ac);color:#fff;}
.fld{margin-bottom:13px;}
.fld label{font-size:12px;color:var(--tx2);display:block;margin-bottom:5px;}
.inp{width:100%;padding:11px 13px;background:var(--bg3);border:1px solid var(--br);border-radius:11px;color:var(--tx);font-size:14px;outline:none;transition:border-color .2s;}
.inp:focus{border-color:var(--ac);}
.inp::placeholder{color:var(--tx3);}
.abtn{width:100%;padding:13px;background:var(--ac);border:none;border-radius:11px;color:#fff;font-size:15px;font-weight:600;cursor:pointer;margin-top:4px;}
.abtn:active{opacity:.85;}
.remb{display:flex;align-items:center;gap:8px;margin:9px 0 3px;cursor:pointer;font-size:13px;color:var(--tx2);}
.remb input{width:15px;height:15px;accent-color:var(--ac);}
.aerr{font-size:12px;color:var(--rd);margin-top:5px;min-height:15px;}
.ainfo{font-size:11px;color:var(--tx3);margin-top:10px;text-align:center;line-height:1.5;}

/* ─── APP ─── */
#app{display:none;height:100dvh;position:relative;overflow:hidden;}
#app.on{display:flex;}

/* ─── SIDEBAR ─── */
.sb{width:310px;min-width:260px;background:var(--bg2);border-right:1px solid var(--br);display:flex;flex-direction:column;height:100dvh;flex-shrink:0;}
.sbh{padding:14px 12px 10px;border-bottom:1px solid var(--br);display:flex;align-items:center;gap:7px;}
.mav{width:34px;height:34px;border-radius:50%;background:var(--ac);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;cursor:pointer;flex-shrink:0;user-select:none;}
.sbt{font-size:15px;font-weight:600;flex:1;}
.ib{width:32px;height:32px;border-radius:50%;background:transparent;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--tx2);transition:background .15s;flex-shrink:0;}
.ib:hover{background:var(--bg3);}
.sw{padding:9px 11px;position:relative;}
.si{position:absolute;left:21px;top:50%;transform:translateY(-50%);color:var(--tx3);pointer-events:none;}
.sinp{width:100%;padding:8px 11px 8px 31px;background:var(--bg3);border:1px solid var(--br);border-radius:11px;color:var(--tx);font-size:13px;outline:none;}
.sinp::placeholder{color:var(--tx3);}
.tabs{display:flex;border-bottom:1px solid var(--br);padding:0 11px;}
.tbtn{flex:1;padding:8px 3px;border:none;background:transparent;color:var(--tx2);font-size:12px;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;}
.tbtn.on{color:var(--ac2);border-bottom-color:var(--ac2);}
.cl{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;}
.cl::-webkit-scrollbar{width:3px;}
.cl::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px;}

/* chat list item */
.ci{display:flex;align-items:center;gap:10px;padding:11px 13px;cursor:pointer;transition:background .15s;border-bottom:1px solid var(--br);}
.ci:hover,.ci.on{background:var(--bg3);}
.cav{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:15px;flex-shrink:0;position:relative;}
.od{position:absolute;bottom:1px;right:1px;width:10px;height:10px;background:var(--gn);border-radius:50%;border:2px solid var(--bg2);}
.cii{flex:1;min-width:0;}
.cnm{font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cpv{font-size:12px;color:var(--tx2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;}
.cmeta{display:flex;flex-direction:column;align-items:flex-end;gap:3px;}
.ctm{font-size:11px;color:var(--tx3);}
.ubadge{background:var(--ac);color:#fff;font-size:10px;font-weight:600;padding:2px 5px;border-radius:9px;min-width:17px;text-align:center;}
.delbtn{background:transparent;border:none;color:var(--rd);cursor:pointer;padding:2px;opacity:0;transition:opacity .15s;display:flex;align-items:center;}
.ci:hover .delbtn{opacity:1;}

/* ─── CHAT ─── */
.ca{flex:1;display:flex;flex-direction:column;min-width:0;height:100dvh;background:var(--bg);}
.est{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:var(--tx3);}
.ei{font-size:46px;opacity:.2;}

.chh{display:flex;align-items:center;gap:9px;padding:11px 14px;border-bottom:1px solid var(--br);background:var(--bg2);position:relative;flex-shrink:0;}
.chn{font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.chs{font-size:11px;color:var(--gn);}
.ctxm{position:absolute;right:10px;top:52px;background:var(--bg2);border:1px solid var(--br);border-radius:12px;padding:5px;z-index:100;min-width:190px;display:none;box-shadow:0 8px 28px rgba(0,0,0,.5);}
.ctxm.on{display:block;}
.cxi{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:8px;cursor:pointer;font-size:13px;transition:background .15s;}
.cxi:hover{background:var(--bg3);}
.cxi.rd{color:var(--rd);}

.msgs{flex:1;overflow-y:auto;padding:10px 13px;display:flex;flex-direction:column;gap:3px;-webkit-overflow-scrolling:touch;scroll-behavior:smooth;}
.msgs::-webkit-scrollbar{width:3px;}
.msgs::-webkit-scrollbar-thumb{background:var(--bg3);border-radius:3px;}
.mday{text-align:center;font-size:11px;color:var(--tx3);margin:7px 0;position:relative;}
.mday::before,.mday::after{content:'';position:absolute;top:50%;width:26%;height:1px;background:var(--br);}
.mday::before{left:0;}.mday::after{right:0;}
.mw{display:flex;flex-direction:column;max-width:78%;}
.mw.me{align-self:flex-end;align-items:flex-end;}
.mw.ot{align-self:flex-start;align-items:flex-start;}
.mb{padding:9px 12px;border-radius:16px;font-size:14px;line-height:1.45;word-break:break-word;}
.me .mb{background:#6c63ff;color:#fff;border-bottom-right-radius:4px;}
.ot .mb{background:var(--bg4);color:var(--tx);border-bottom-left-radius:4px;}
.mt{font-size:10px;color:var(--tx3);margin:2px 4px;}
.mimg{max-width:220px;width:100%;border-radius:11px;margin:3px 0;cursor:pointer;display:block;}
.mvid{max-width:220px;width:100%;border-radius:11px;margin:3px 0;display:block;}
.maud{width:190px;height:34px;margin:2px 0;border-radius:8px;}
.msn{font-size:11px;color:var(--ac2);margin-bottom:2px;font-weight:500;}

/* ─── INPUT ─── */
.inpa{padding:8px 11px;border-top:1px solid var(--br);background:var(--bg2);display:flex;align-items:flex-end;gap:5px;position:relative;flex-shrink:0;}
.minp{flex:1;padding:9px 13px;background:var(--bg3);border:1px solid var(--br);border-radius:20px;color:var(--tx);font-size:14px;outline:none;resize:none;max-height:100px;line-height:1.4;transition:border-color .2s;}
.minp:focus{border-color:var(--ac);}
.minp::placeholder{color:var(--tx3);}
.sndb{width:38px;height:38px;border-radius:50%;background:var(--ac);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0;}
.sndb:active{opacity:.8;}
.attb{width:32px;height:32px;border-radius:50%;background:transparent;border:none;cursor:pointer;color:var(--tx2);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:color .15s;}
.attb:active{color:var(--ac2);}
.ep{position:absolute;bottom:60px;left:10px;background:var(--bg2);border:1px solid var(--br);border-radius:14px;padding:9px;width:min(290px,88vw);display:none;flex-wrap:wrap;gap:2px;z-index:50;max-height:180px;overflow-y:auto;box-shadow:0 8px 24px rgba(0,0,0,.45);}
.ep.on{display:flex;}
.epb{width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:18px;border-radius:7px;cursor:pointer;border:none;background:transparent;}
.epb:hover{background:var(--bg3);}

/* ─── AUDIO REC ─── */
.recb{display:none;align-items:center;gap:9px;padding:8px 13px;background:var(--bg2);border-top:1px solid var(--br);flex-shrink:0;}
.recb.on{display:flex;}
.rdot{width:9px;height:9px;border-radius:50%;background:var(--rd);animation:pulse 1s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.25;}}
.rtm{font-size:13px;font-weight:500;color:var(--rd);min-width:38px;}
.rcan{flex:1;font-size:13px;color:var(--tx2);cursor:pointer;}
.rsnd{padding:6px 14px;background:var(--ac);border:none;border-radius:9px;color:#fff;font-size:13px;font-weight:500;cursor:pointer;}

/* ─── VIDEO REC MODAL ─── */
#vr{position:fixed;inset:0;background:rgba(0,0,0,.94);z-index:500;display:none;flex-direction:column;align-items:center;justify-content:center;gap:14px;}
#vr.on{display:flex;}
#vrprev{width:min(340px,90vw);border-radius:14px;background:#000;}
.vrst{font-size:13px;color:var(--tx2);}
.vrbts{display:flex;gap:14px;}
.vrb{width:54px;height:54px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:22px;}
.vrb.rc{background:var(--rd);}
.vrb.fl{background:var(--bg3);}
.vrb.sn{background:var(--ac);}
.vrb.cl{background:var(--bg4);}

/* ─── CALL ─── */
#callsc{position:fixed;inset:0;background:linear-gradient(160deg,#1a1535,#0e0f14);z-index:400;display:none;flex-direction:column;align-items:center;justify-content:space-between;padding:56px 20px 44px;}
#callsc.on{display:flex;}
.clav{width:96px;height:96px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:34px;font-weight:600;margin-bottom:10px;}
.clnm{font-size:21px;font-weight:600;margin-bottom:6px;text-align:center;}
.clst{font-size:13px;color:var(--tx2);text-align:center;}
.clbts{display:flex;gap:18px;flex-wrap:wrap;justify-content:center;}
.clb{width:60px;height:60px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:2px;}
.clb span{font-size:10px;color:#fff;}
.cb-end{background:var(--rd);}
.cb-mut{background:var(--bg3);}
.cb-spk{background:var(--bg3);}
.cb-cam{background:var(--bg3);}
#cllocv{position:absolute;bottom:130px;right:18px;width:96px;border-radius:10px;display:none;}

/* ─── CONTACTS ─── */
.cpnl{position:fixed;right:0;top:0;bottom:0;width:min(295px,100vw);background:var(--bg2);border-left:1px solid var(--br);z-index:200;transform:translateX(100%);transition:transform .26s;display:flex;flex-direction:column;}
.cpnl.on{transform:translateX(0);}
.pnh{display:flex;align-items:center;justify-content:space-between;padding:15px 13px;border-bottom:1px solid var(--br);}
.pnt{font-size:14px;font-weight:600;}
.addc{margin:9px 13px;padding:9px;background:var(--bg3);border:1px dashed var(--br);border-radius:11px;cursor:pointer;text-align:center;font-size:13px;color:var(--tx2);}
.addc:hover{border-color:var(--ac);color:var(--ac2);}
.cit{display:flex;align-items:center;gap:10px;padding:10px 13px;transition:background .15s;}
.cit:hover{background:var(--bg3);}

/* ─── SETTINGS PANEL ─── */
.spnl{position:fixed;right:0;top:0;bottom:0;width:min(310px,100vw);background:var(--bg2);border-left:1px solid var(--br);z-index:250;transform:translateX(100%);transition:transform .26s;display:flex;flex-direction:column;overflow-y:auto;}
.spnl.on{transform:translateX(0);}
.ssel{padding:16px 15px;border-top:1px solid var(--br);}
.sst{font-size:11px;color:var(--tx3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;}
.stog{display:flex;align-items:center;justify-content:space-between;padding:9px 0;}
.stog label{font-size:14px;cursor:pointer;display:flex;align-items:center;gap:7px;}
.tsw{position:relative;width:42px;height:22px;cursor:pointer;flex-shrink:0;}
.tsw input{opacity:0;width:0;height:0;}
.tsl{position:absolute;inset:0;background:var(--bg4);border-radius:22px;transition:.28s;}
.tsl::before{content:'';position:absolute;height:16px;width:16px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.28s;}
.tsw input:checked+.tsl{background:var(--ac);}
.tsw input:checked+.tsl::before{transform:translateX(20px);}
.srow{display:flex;align-items:center;gap:10px;padding:10px 0;cursor:pointer;border-radius:9px;}
.srow:hover{opacity:.8;}
.srow-ic{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.srow-tx{font-size:14px;}
.srow-sub{font-size:11px;color:var(--tx3);}
.lgout{width:100%;padding:11px;background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.2);border-radius:11px;color:var(--rd);font-size:14px;font-weight:500;cursor:pointer;}
.lgout:hover{background:rgba(248,113,113,.2);}

/* ─── PROFILE PANEL ─── */
.ppnl{position:fixed;inset:0;background:var(--bg2);z-index:300;display:none;flex-direction:column;overflow-y:auto;}
.ppnl.on{display:flex;}
.ppav{width:84px;height:84px;border-radius:50%;background:var(--ac);display:flex;align-items:center;justify-content:center;font-size:30px;font-weight:600;margin:0 auto 10px;}
.ppnm{text-align:center;font-size:19px;font-weight:600;margin-bottom:3px;}
.ppph{text-align:center;font-size:13px;color:var(--tx2);}

/* ─── MODALS ─── */
.mov{position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:350;display:none;align-items:center;justify-content:center;padding:14px;}
.mov.on{display:flex;}
.mbox{background:var(--bg2);border:1px solid var(--br);border-radius:18px;padding:22px;width:100%;max-width:350px;}
.mbox h3{font-size:15px;font-weight:600;margin-bottom:14px;}
.mbt{padding:9px 16px;border-radius:9px;border:none;cursor:pointer;font-size:13px;font-weight:500;}
.mbt.p{background:var(--ac);color:#fff;}
.mbt.s{background:var(--bg3);color:var(--tx2);}
.mbt:hover{opacity:.85;}
.macts{display:flex;gap:7px;margin-top:14px;justify-content:flex-end;}
.ufc{display:flex;align-items:center;gap:9px;background:var(--bg3);border-radius:9px;padding:9px 11px;margin-top:9px;}
.gcip{display:inline-flex;align-items:center;gap:4px;background:var(--bg4);border-radius:7px;padding:3px 8px;font-size:12px;margin:2px;}

/* ─── MOBILE ─── */
@media(max-width:680px){
  .sb{width:100%;position:absolute;inset:0;z-index:10;}
  .sb.hid{display:none;}
  .ca{position:absolute;inset:0;z-index:5;display:none;}
  .ca.on{display:flex;}
  .chh{padding:9px 11px;}
}
.hid{display:none!important;}

/* SVG icons helper */
svg{display:inline-block;vertical-align:middle;}
</style>
</head>
<body>

<!-- ═══ AUTH ═══ -->
<div id="auth">
  <div class="logo">Vibe</div>
  <div class="logo-sub">Мессенджер нового поколения</div>
  <div class="acard">
    <div class="atabs">
      <button class="atab on" id="tab-l" onclick="stab('l')">Войти</button>
      <button class="atab" id="tab-r" onclick="stab('r')">Регистрация</button>
    </div>
    <div id="lf">
      <div class="fld"><label>Номер телефона</label><input class="inp" type="tel" id="lp" placeholder="+7 999 123-45-67"></div>
      <div class="fld"><label>Пароль</label><input class="inp" type="password" id="lpw" placeholder="••••••••"></div>
      <label class="remb"><input type="checkbox" id="rem" checked> Запомнить меня</label>
      <button class="abtn" onclick="doLogin()">Войти</button>
      <div class="aerr" id="lerr"></div>
    </div>
    <div id="rf" class="hid">
      <div class="fld"><label>Имя</label><input class="inp" type="text" id="rn" placeholder="Иван Иванов"></div>
      <div class="fld"><label>Номер телефона</label><input class="inp" type="tel" id="rp" placeholder="+7 999 123-45-67"></div>
      <div class="fld"><label>Пароль</label><input class="inp" type="password" id="rpw" placeholder="Минимум 6 символов"></div>
      <button class="abtn" onclick="doRegister()">Создать аккаунт</button>
      <div class="aerr" id="rerr"></div>
      <div class="ainfo">Регистрируясь, вы соглашаетесь с условиями использования</div>
    </div>
  </div>
</div>

<!-- ═══ APP ═══ -->
<div id="app">
  <!-- SIDEBAR -->
  <div class="sb" id="sb">
    <div class="sbh">
      <div class="mav" id="myav" onclick="openProfile()">А</div>
      <div class="sbt">Vibe</div>
      <!-- SVG icons -->
      <button class="ib" onclick="openSettings()" title="Настройки">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </button>
      <button class="ib" onclick="openContacts()" title="Контакты">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </button>
      <button class="ib" onclick="openNewGroup()" title="Новая группа" style="font-size:20px;font-weight:400;">＋</button>
    </div>
    <div class="sw">
      <span class="si"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
      <input class="sinp" type="text" placeholder="Поиск..." oninput="fchats()">
    </div>
    <div class="tabs">
      <button class="tbtn on" onclick="sctab('all',this)">Все</button>
      <button class="tbtn" onclick="sctab('personal',this)">Личные</button>
      <button class="tbtn" onclick="sctab('groups',this)">Группы</button>
    </div>
    <div class="cl" id="cl"></div>
  </div>

  <!-- CHAT AREA -->
  <div class="ca" id="ca">
    <div class="est" id="est">
