// AUDIO REC
G.startRec=async()=>{
  if(aRec)return;
  try{
    const stream=await navigator.mediaDevices.getUserMedia({audio:true});
    aChunks=[];
    aRec=new MediaRecorder(stream);
    aRec.ondataavailable=e=>aChunks.push(e.data);
    aRec.start();
    $('recb').classList.add('on');$('inpa').style.display='none';
    recSec=0;$('rtm').textContent='0:00';
    recTimer=setInterval(()=>{recSec++;const m=Math.floor(recSec/60),s=recSec%60;$('rtm').textContent=`${m}:${s.toString().padStart(2,'0')}`;},1000);
  }catch(e){alert('Нет доступа к микрофону');}
};
G.cancelRec=()=>{
  if(aRec){aRec.stream.getTracks().forEach(t=>t.stop());aRec=null;}
  clearInterval(recTimer);$('recb').classList.remove('on');$('inpa').style.display='flex';
};
G.sendRec=()=>{
  if(!aRec)return;
  aRec.onstop=async()=>{
    const blob=new Blob(aChunks,{type:'audio/webm'});
    const reader=new FileReader();
    reader.onload=async e=>{
      const key='audio_'+Date.now();
      await saveMedia(key,e.target.result);
      await doSend({mediaKey:key,mediaUrl:e.target.result.slice(0,100),mediaType:'audio',text:'🎤 Аудио'});
    };
    reader.readAsDataURL(blob);
    aRec.stream.getTracks().forEach(t=>t.stop());aRec=null;
  };
  aRec.stop();clearInterval(recTimer);
  $('recb').classList.remove('on');$('inpa').style.display='flex';
};

// VIDEO REC
G.openVR=async()=>{
  try{
    vrFace='user';
    vrStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:vrFace},audio:true});
    $('vrprev').srcObject=vrStream;
    $('vr').classList.add('on');
    $('vrst').textContent='Нажмите ● для записи';
    $('vrrec').textContent='●';$('vrsnd').classList.add('hid');
    vrRing=false;vrChunks=[];
  }catch(e){alert('Нет доступа к камере');}
};
G.closeVR=()=>{
  if(vrStream)vrStream.getTracks().forEach(t=>t.stop());
  if(vrRec&&vrRec.state==='recording')vrRec.stop();
  vrStream=null;vrRec=null;vrRing=false;
  $('vr').classList.remove('on');
};
G.toggleVRec=()=>{
  if(!vrRing){
    vrChunks=[];vrRec=new MediaRecorder(vrStream);
    vrRec.ondataavailable=e=>vrChunks.push(e.data);
    vrRec.start();vrRing=true;
    $('vrrec').textContent='⏹';$('vrrec').style.background='#555';
    $('vrst').textContent='Запись...';
  }else{
    vrRec.onstop=()=>{$('vrsnd').classList.remove('hid');$('vrst').textContent='Готово — нажмите ➤';};
    vrRec.stop();vrRing=false;
    $('vrrec').textContent='●';$('vrrec').style.background='var(--rd)';
  }
};
G.flipCam=async()=>{
  if(vrStream)vrStream.getTracks().forEach(t=>t.stop());
  vrFace=vrFace==='user'?'environment':'user';
  vrStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:vrFace},audio:true});
  $('vrprev').srcObject=vrStream;
};
G.sendVRec=async()=>{
  const blob=new Blob(vrChunks,{type:'video/webm'});
  if(blob.size>8*1024*1024){alert('Видео слишком большое (макс. 8 МБ)');return;}
  const reader=new FileReader();
  reader.onload=async e=>{
    const key='video_'+Date.now();
    await saveMedia(key,e.target.result);
    await doSend({mediaKey:key,mediaUrl:e.target.result.slice(0,100),mediaType:'video',text:'🎥 Видеосообщение'});
  };
  reader.readAsDataURL(blob);
  G.closeVR();
};

// ── REAL WebRTC CALLS via Firestore signaling + TURN ──
let pc=null,callDocId=null;

async function setupPC(){
  if(pc){pc.close();}
  pc=new RTCPeerConnection({iceServers:ICE});
  callStream?.getTracks().forEach(t=>pc.addTrack(t,callStream));
  pc.ontrack=e=>{const rv=$('clremv');rv.srcObject=e.streams[0];rv.style.display='block';};
  return pc;
}

G.call=async type=>{
  const nm=$('chn').textContent;
  $('clav').style.background=avc(nm);$('clav').textContent=ini(nm);
  $('clnm').textContent=nm;
  $('clst').textContent=type==='video'?'Видеовызов...':'Аудиовызов...';
  $('callsc').classList.add('on');
  try{callStream=await navigator.mediaDevices.getUserMedia({audio:true,video:type==='video'});}
  catch(e){$('clst').textContent='Нет доступа к камере/микрофону';return;}
  if(type==='video'){$('cllocv').srcObject=callStream;$('cllocv').style.display='block';}
  await setupPC();
  const callRef=doc(collection(db,'calls'));
  callDocId=callRef.id;
  const offerC=collection(callRef,'offerCandidates');
  const answerC=collection(callRef,'answerCandidates');
  pc.onicecandidate=e=>{if(e.candidate)addDoc(offerC,e.candidate.toJSON());};
  const offer=await pc.createOffer();
  await pc.setLocalDescription(offer);
  await setDoc(callRef,{offer:{type:offer.type,sdp:offer.sdp},callType:type,caller:cu.uid,callerName:cu.displayName,chatId:G.cid,createdAt:serverTimestamp()});
  await doSend({text:'📞 '+(type==='video'?'Видеозвонок':'Аудиозвонок')+' | Принять: нажмите кнопку звонка',callId:callDocId,callType:type});
  $('clst').textContent='Ожидание ответа...';
  onSnapshot(callRef,async snap=>{
    const d=snap.data();
    if(d?.answer&&pc&&pc.signalingState!=='stable')try{await pc.setRemoteDescription(new RTCSessionDescription(d.answer));$('clst').textContent=type==='video'?'Видеозвонок':'Аудиозвонок';}catch(e){}
    if(d?.ended&&d.caller!==cu.uid)G.endCall();
  });
  onSnapshot(answerC,snap=>{snap.docChanges().forEach(ch=>{if(ch.type==='added'&&pc)pc.addIceCandidate(new RTCIceCandidate(ch.doc.data())).catch(()=>{});});});
  setTimeout(()=>{if($('clst').textContent.includes('Ожидание'))$('clst').textContent='Нет ответа';},30000);
};

G.answerCall=async(cid,type)=>{
  $('clst').textContent='Соединяемся...';$('callsc').classList.add('on');
  try{callStream=await navigator.mediaDevices.getUserMedia({audio:true,video:type==='video'});}catch(e){return;}
  if(type==='video'){$('cllocv').srcObject=callStream;$('cllocv').style.display='block';}
  callDocId=cid;await setupPC();
  const callRef=doc(db,'calls',cid);
  const offerC=collection(callRef,'offerCandidates');
  const answerC=collection(callRef,'answerCandidates');
  pc.onicecandidate=e=>{if(e.candidate)addDoc(answerC,e.candidate.toJSON());};
  const cd=(await getDoc(callRef)).data();
  await pc.setRemoteDescription(new RTCSessionDescription(cd.offer));
  const answer=await pc.createAnswer();
  await pc.setLocalDescription(answer);
  await updateDoc(callRef,{answer:{type:answer.type,sdp:answer.sdp}});
  onSnapshot(offerC,snap=>{snap.docChanges().forEach(ch=>{if(ch.type==='added'&&pc)pc.addIceCandidate(new RTCIceCandidate(ch.doc.data())).catch(()=>{});});});
  $('clst').textContent=type==='video'?'Видеозвонок':'Аудиозвонок';
};

G.endCall=async()=>{
  if(pc){pc.close();pc=null;}
  if(callStream){callStream.getTracks().forEach(t=>t.stop());callStream=null;}
  if(callDocId){try{await updateDoc(doc(db,'calls',callDocId),{ended:true});}catch(e){}}
  callDocId=null;
  $('callsc').classList.remove('on');
  $('cllocv').style.display='none';$('clremv').style.display='none';
};
G.toggleMute=()=>{if(callStream){const t=callStream.getAudioTracks()[0];if(t){t.enabled=!t.enabled;$('btnmut').style.opacity=t.enabled?'1':'.4';}}};
G.toggleCam=()=>{if(callStream){const t=callStream.getVideoTracks()[0];if(t){t.enabled=!t.enabled;$('btncam').style.opacity=t.enabled?'1':'.4';}}};
G.toggleSpk=()=>{};

