  G.openChat(ref.id,'personal');
};

// MESSAGES
function subMsgs(chatId){
  if(unsubM)unsubM();
  const q=query(collection(db,'chats',chatId,'messages'),orderBy('time','asc'));
  unsubM=onSnapshot(q,async snap=>{
    const msgs=snap.docs.map(d=>({id:d.id,...d.data()}));
    const area=$('msgs');
    let ld='',html='';
    for(const m of msgs){
      const day=fd(m.time);
      if(day!==ld){html+=`<div class="mday">${day}</div>`;ld=day;}
      const me=m.sender===cu.uid;

      // Load media from IndexedDB if we have a media key
      let mediaSrc=m.mediaUrl||'';
      if(m.mediaKey&&!mediaSrc.startsWith('data:')){
        const cached=await getMedia(m.mediaKey);
        if(cached)mediaSrc=cached;
      }

      let cnt='';
      if(mediaSrc){
        const mt=m.mediaType||'';
        if(mt==='video'||mediaSrc.startsWith('data:video'))cnt=`<video class="mvid" src="${mediaSrc}" controls playsinline></video>`;
        else if(mt==='audio'||mediaSrc.startsWith('data:audio'))cnt=`<audio class="maud" src="${mediaSrc}" controls></audio>`;
        else cnt=`<img class="mimg" src="${mediaSrc}" loading="lazy">`;
      }
      // Show answer button for incoming calls
      if(m.callId&&m.sender!==cu.uid){
        cnt+=`<div style="margin-top:6px;"><button onclick="G.answerCall('${m.callId}','${m.callType||'audio'}')" style="padding:6px 14px;background:var(--gn);border:none;border-radius:8px;color:#000;font-size:12px;font-weight:600;cursor:pointer;">📞 Ответить</button></div>`;
      }
      if(m.text&&!m.callId)cnt+=`<span>${m.text}</span>`;
      if(m.text&&m.callId)cnt+=`<span style="opacity:.7;font-size:12px;">${m.text}</span>`;
      const snl=(!me&&m.senderName)?`<div class="msn">${m.senderName}</div>`:'';
      html+=`<div class="mw ${me?'me':'ot'}">${snl}<div class="mb">${cnt}</div><div class="mt">${ft(m.time)}${me?' ✓✓':''}</div></div>`;
    }
    area.innerHTML=html;
    area.scrollTop=area.scrollHeight;
  });
}

async function doSend(data){
  if(!G.cid)return;
  await addDoc(collection(db,'chats',G.cid,'messages'),{...data,sender:cu.uid,senderName:cu.displayName,time:serverTimestamp()});
  const cs=await getDoc(doc(db,'chats',G.cid));
  const upd={lastMsg:data.text||'📎 Медиа',lastTime:serverTimestamp()};
  cs.data().members.filter(m=>m!==cu.uid).forEach(m=>{upd[`unread.${m}`]=((cs.data().unread||{})[m]||0)+1;});
  await updateDoc(doc(db,'chats',G.cid),upd);
}

G.send=async()=>{
  const inp=$('minp'),text=inp.value.trim();
  if(!text||!G.cid)return;
  inp.value='';ar(inp);
  await doSend({text});
};

G.attach=async input=>{
  const file=input.files[0];
  if(!file||!G.cid)return;
  if(file.size>8*1024*1024){alert('Максимум 8 МБ');input.value='';return;}
  const reader=new FileReader();
  reader.onload=async e=>{
    const data=e.target.result;
    const key='media_'+Date.now()+'_'+Math.random().toString(36).slice(2);
    await saveMedia(key,data); // save to IndexedDB
    const mt=file.type.startsWith('video')?'video':'image';
    // Store only a tiny thumb reference in Firestore, actual data in IndexedDB
    await doSend({mediaKey:key,mediaUrl:data.slice(0,300),mediaType:mt,text:mt==='video'?'🎥 Видео':'📷 Фото'});
  };
  reader.readAsDataURL(file);
  input.value='';
};

// DELETE & CLEAR CHAT
G.delChat=async()=>{
  const id=G.chatToDel||G.cid;if(!id)return;
  closeModal('mdelc');
  const ms=await getDocs(collection(db,'chats',id,'messages'));
  const batch=writeBatch(db);
  ms.docs.forEach(d=>batch.delete(d.ref));
  batch.delete(doc(db,'chats',id));
  await batch.commit();
  if(id===G.cid){G.cid=null;$('ach').classList.add('hid');$('est').classList.remove('hid');$('sb').classList.remove('hid');$('ca').classList.remove('on');}
  G.chatToDel=null;
};

G.clearChat=async()=>{
  const id=G.chatToClear||G.cid;if(!id)return;
  closeModal('mclearc');
  const ms=await getDocs(collection(db,'chats',id,'messages'));
  const batch=writeBatch(db);
  ms.docs.forEach(d=>batch.delete(d.ref));
  await batch.commit();
  await updateDoc(doc(db,'chats',id),{lastMsg:'',lastTime:serverTimestamp()});
  G.chatToClear=null;
};

