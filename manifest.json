const FC={apiKey:"AIzaSyAhD-Y2nf59Z9ESrIYqPRxTsuyXvX2LQEQ",authDomain:"vibe-e7317.firebaseapp.com",projectId:"vibe-e7317",storageBucket:"vibe-e7317.firebasestorage.app",messagingSenderId:"179418567747",appId:"1:179418567747:web:4226132681f26e72cb30f6"};
