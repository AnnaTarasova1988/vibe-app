// helpers
const p2e=p=>p.replace(/\D/g,'')+`@vibe.app`;
const ini=n=>n?n.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase():'?';
const avc=s=>{const c=['#6c63ff','#a78bfa','#60a5fa','#34d399','#f59e0b','#f87171','#fb923c','#e879f9'];let h=0;for(const x of s)h=(h*31+x.charCodeAt(0))%c.length;return c[h];};
const ft=ts=>{if(!ts)return'';const d=ts.toDate?ts.toDate():new Date(ts);return d.toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'});};
const fd=ts=>{if(!ts)return'';const d=ts.toDate?ts.toDate():new Date(ts),t=new Date();if(d.toDateString()===t.toDateString())return'Сегодня';const y=new Date(t);y.setDate(t.getDate()-1);if(d.toDateString()===y.toDateString())return'Вчера';return d.toLocaleDateString('ru',{day:'numeric',month:'long'});};

