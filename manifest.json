// AUTH
G.login=async()=>{
  const phone=$('lp').value.trim(),pass=$('lpw').value,rem=$('rem').checked,err=$('lerr');
  err.textContent='';
  if(!phone||!pass){err.textContent='Заполните все поля';return;}
  try{
    // Set persistence BEFORE sign in — this is what makes "remember me" work
    await setPersistence(auth,rem?browserLocalPersistence:browserSessionPersistence);
    await signInWithEmailAndPassword(auth,p2e(phone),pass);
  }catch(e){err.textContent=e.code.includes('invalid')||e.code.includes('wrong')?'Неверный номер или пароль':'Ошибка: '+e.message;}
};

G.reg=async()=>{
  const nm=$('rn').value.trim(),ph=$('rp').value.trim(),pw=$('rpw').value,err=$('rerr');
  err.textContent='';
  if(!nm||!ph||!pw){err.textContent='Заполните все поля';return;}
  if(pw.length<6){err.textContent='Пароль минимум 6 символов';return;}
  try{
    const email=p2e(ph);
    const cred=await createUserWithEmailAndPassword(auth,email,pw);
    await updateProfile(cred.user,{displayName:nm});
    await setDoc(doc(db,'users',cred.user.uid),{uid:cred.user.uid,name:nm,phone:ph,email,createdAt:serverTimestamp()});
  }catch(e){err.textContent=e.code==='auth/email-already-in-use'?'Номер уже зарегистрирован':e.message;}
};

